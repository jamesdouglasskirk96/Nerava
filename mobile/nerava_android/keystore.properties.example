# Copy this file to keystore.properties and fill in your values.
# DO NOT commit keystore.properties to version control.
#
# Generate keystore:
#   keytool -genkey -v -keystore nerava-release.keystore \
#     -alias nerava -keyalg RSA -keysize 2048 -validity 10000
#
storeFile=nerava-release.keystore
storePassword=
keyAlias=nerava
keyPassword=
